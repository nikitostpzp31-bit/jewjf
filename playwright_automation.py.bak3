async def open_find_my(page: Page):
    await page.goto("https://www.icloud.com/find/", wait_until="networkidle", timeout=30000)
    await asyncio.sleep(3)
    return {"ok": True, "screenshot": await page.screenshot()}


async def open_mail(page: Page):
    await page.goto("https://www.icloud.com/mail/", wait_until="networkidle", timeout=30000)
    await asyncio.sleep(3)
    return {"ok": True, "emails": []}


async def get_security_info(page: Page):
    await page.goto(URL_SECURITY, wait_until="networkidle", timeout=30000)
    await asyncio.sleep(2)
    txt = await _page_text(page)
    return {"ok": True, "info": txt[:2000]}
