# Telegram Bot Configuration
# Copy this file to .env and fill in your values

# Required: Telegram Bot Token (get from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Required: Your Telegram User ID (get from @userinfobot)
OWNER_TELEGRAM_ID=123456789

# Recommended: Secret phrase for accessing /setup command
SECRET_PHRASE=change_this_to_your_secret

# Recommended: Fernet encryption key for storing passwords
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Optional: Custom paths
DB_PATH=icloud_monitor.db
LOG_PATH=icloud_monitor.log

# Optional: Dropbox backup integration
DROPBOX_TOKEN=

# Optional: Google Drive backup integration
GDRIVE_CREDS_JSON=service_account.json
GDRIVE_FOLDER_ID=
